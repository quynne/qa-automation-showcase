{
  "name": "qa-automation-showcase",
  "version": "1.0.0",
  "description": "AI-driven QA automation framework — Playwright (web + API), multi-agent review, CI/CD",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-checkout",
    "test:api": "playwright test --project=api-setup --project=api-users",
    "test:smoke": "playwright test --grep @smoke",
    "test:security": "playwright test --grep @security",
    "report": "playwright show-report ./reports/html",
    "report:allure": "npx allure serve ./reports/allure",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "allure-playwright": "^3.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  }
}
