{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": ["./_src/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
