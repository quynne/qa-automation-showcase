{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@api/*": ["./_src/api/*"],
      "@ui/*": ["./_src/ui/*"]
    }
  },
  "include": ["./_src/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
